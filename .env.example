TAILSCALE_IP=100.x.y.z
SECURITY_HUB_PORT=8099
SECURITY_HUB_WEBHOOK_SECRET=change-this-long-random-value

ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

HOST_LABEL=homelab-srv01
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_SECURITY_DIR=/openclaw/security-alerts
OPENCLAW_DASHBOARD_DIR=/openclaw/dashboard
OPENCLAW_HOST_SECURITY_DIR=/home/your-user/.openclaw/workspace/security-alerts
OPENCLAW_HOST_DASHBOARD_DIR=/home/your-user/.openclaw/workspace/dashboard

ENABLE_AUTH_LOG_MONITOR=true
AUTH_LOG_PATH=/host/auth.log
AUTH_FAILURE_THRESHOLD=5
AUTH_WINDOW_SECONDS=300
AUTH_ALERT_COOLDOWN_SECONDS=1800

ENABLE_OPENCLAW_MONITOR=true
OPENCLAW_CHECK_INTERVAL_SECONDS=60
OPENCLAW_ALERT_COOLDOWN_SECONDS=1800

ENABLE_DISK_MONITOR=true
DISK_CHECK_INTERVAL_SECONDS=300
DISK_ALERT_THRESHOLD_PERCENT=90
HOST_ROOT_PATH=/host-root
HOST_PROC_PATH=/host-proc

ENABLE_SECURITY_POSTURE_MONITOR=true
SECURITY_POSTURE_INTERVAL_SECONDS=900
SECURITY_POSTURE_ALERT_COOLDOWN_SECONDS=3600
ALLOWED_GLOBAL_TCP_PORTS=22
ALLOWED_TAILSCALE_TCP_PORTS=8099
IGNORE_TAILSCALE_EPHEMERAL_TCP_PORTS=true
EXPECTED_SSH_ALLOW_USERS=your-user

OUTPUT_UID=1000
OUTPUT_GID=1000
